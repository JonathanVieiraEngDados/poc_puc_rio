# Copie este arquivo para .env e preencha com sua chave real:
#   cp .env.example .env

# Obrigatório: chave da API da OpenAI usada pelo agente (ChatOpenAI / create_csv_agent).
OPENAI_API_KEY=sk-...

# Opcionais (já têm padrões sensatos no código):
# DATASET_CSV=data/TestPuc-Rio.csv        # caminho para o dataset (padrão: dataset de exemplo)
# GRADIO_SERVER_NAME=127.0.0.1        # use 0.0.0.0 para expor na rede local
# GRADIO_SERVER_PORT=7860
# GRADIO_SHARE=false                  # true gera um link público temporário do Gradio
